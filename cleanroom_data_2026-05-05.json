    {
      "id": 1,
      "name": "SiO2 etch CF4/CHF3 — standard",
      "tool": "RIE etcher (Oxford)",
      "type": "etch",
      "material": "SiO2",
      "desc": "Reliable isotropic SiO2 etch for patterning 500 nm thermal oxide on Si. Good selectivity over Si (~10:1). Suitable for contact holes and isolation trenches.",
      "params": [
        [
          "CF4 flow",
          "20 sccm"
        ],
        [
          "CHF3 flow",
          "10 sccm"
        ],
        [
          "RF power",
          "100 W"
        ],
        [
          "Pressure",
          "50 mTorr"
        ],
        [
          "DC bias",
          "~180 V"
        ],
        [
          "Chuck temp",
          "20 °C"
        ],
        [
          "He backside cooling",
          "10 Torr"
        ]
      ],
      "rate": 45,
      "runit": "nm/min",
      "expYield": 92,
      "substrate": "4″ Si (100)",
      "thickness": "500 nm thermal SiO2",
      "tips": "Condition chamber with 5 min dummy run before first wafer. Etch rate drops ~8% as electrode ages — confirm with profilometer before critical runs.",
      "tags": [
        "CMOS-compatible",
        "oxide-etch",
        "standard"
      ],
